# Server
ADDR=:8080
DATABASE_URL=postgres://mcpguard:mcpguard@localhost:5432/mcpguard?sslmode=disable
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
SEED_ON_START=true
AUTH_DEV_MODE=true

# Google OAuth (dashboard login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Slack (downstream MCP connector)
# Bot User OAuth Token (xoxb-...) or User OAuth Token (xoxp-...). App-level tokens (xapp-) are not supported.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_MCP_PATH=slack-mcp-server
SLACK_ALLOWED_CHANNEL=C00000000
